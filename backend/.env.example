# ─── QueueStorm Investigator — backend environment ───────────────────────────
# Copy this file to backend/.env and fill in real values.
# backend/.env is git-ignored; backend/.env.example is the template.

# Google AI Studio key (Gemini). Required for the NLU extraction path.
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# Optional: override the auto-detected Gemini model.
# (Leave commented out to let gemini_client.py probe-and-pin a working model.)
# GEMINI_MODEL=gemini-2.5-flash

# Port the FastAPI backend binds to when launched with `python backend/main.py`.
# Read in backend/main.py as BACKEND_PORT. Defaults to 8000 if unset.
# The frontend reads its matching value at build time (see FRONTEND_API_PORT
# note in frontend/README.md) so the two stay in sync. Choose any free port,
# e.g. 8000, 8080, 3000. Match it on the frontend side.
BACKEND_PORT=8000
